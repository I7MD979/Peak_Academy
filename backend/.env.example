PORT=4000
NODE_ENV=development
FRONTEND_URL=https://peak-academy.net
# Comma-separated extra origins (Vercel preview, local dev)
# ALLOWED_ORIGINS=https://peak-academy-xxx.vercel.app,http://localhost:3000

SUPABASE_URL=
SUPABASE_SERVICE_KEY=
# Database password (Dashboard → Settings → Database) — for npm run migrate:payments
# SUPABASE_DB_PASSWORD=
# SUPABASE_DB_REGION=eu-west-2
# Or personal access token (Account → Access Tokens) with database:write
# SUPABASE_ACCESS_TOKEN=

DAILY_API_KEY=

PAYMOB_API_KEY=
PAYMOB_INTEGRATION_ID_CARD=
PAYMOB_INTEGRATION_ID_WALLET=
PAYMOB_HMAC_SECRET=
PAYMOB_IFRAME_ID=

RESEND_API_KEY=
RESEND_FROM=Peak Academy <noreply@peak-academy.net>

DAILY_DOMAIN=peak-academy

# Redis cache (Upstash REST preferred, or REDIS_URL for BullMQ + ioredis cache)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
REDIS_URL=

# Feature flags
# Set after running supabase/migrations/20260609_master_schema_v2.sql
FF_SCHEMA_V2=false
FF_REDIS_CACHE_ENABLED=true
FF_REDIS_QUEUE_ENABLED=false
FF_SENTRY_ENABLED=false
FF_SUBSCRIPTION_RESET=true

SENTRY_DSN=
