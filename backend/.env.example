PORT=4000
NODE_ENV=development
FRONTEND_URL=https://peak-academy.net
# Public API URL (for docs / Vercel): https://your-service.up.railway.app/api
# Comma-separated extra origins (Vercel preview, local dev)
# ALLOWED_ORIGINS=https://peak-academy-xxx.vercel.app,http://localhost:3000

SUPABASE_URL=
# Must match frontend NEXT_PUBLIC_SUPABASE_URL (same project ref, e.g. https://hpczrdvaeazrrrzgtatl.supabase.co)
# service_role secret from Supabase Dashboard → Settings → API (NOT anon key, NOT JWT_SECRET)
# Wrong key → 403 on admin APIs or 500 "Invalid API key"
SUPABASE_SERVICE_KEY=
# alias supported:
# SUPABASE_SERVICE_ROLE_KEY=
# Optional but recommended for JWT verification fallback (publishable anon key)
SUPABASE_ANON_KEY=
# Database password (Dashboard → Settings → Database) — for npm run migrate:payments
# SUPABASE_DB_PASSWORD=
# SUPABASE_DB_REGION=eu-west-2
# Or personal access token (Account → Access Tokens) with database:write
# SUPABASE_ACCESS_TOKEN=

LIVEKIT_URL=wss://peak-academy-kl4maj6p.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

PAYMOB_API_KEY=
PAYMOB_INTEGRATION_ID_CARD=
PAYMOB_INTEGRATION_ID_WALLET=
PAYMOB_HMAC_SECRET=
PAYMOB_IFRAME_ID=

RESEND_API_KEY=
RESEND_FROM=Peak Academy <noreply@peak-academy.net>

# Redis cache (Upstash REST preferred, or REDIS_URL for BullMQ + ioredis cache)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
REDIS_URL=

# Feature flags
# Set after running supabase/migrations/20260609_master_schema_v2.sql
FF_SCHEMA_V2=false
FF_REDIS_CACHE_ENABLED=true
FF_REDIS_QUEUE_ENABLED=false
FF_SENTRY_ENABLED=false
FF_SUBSCRIPTION_RESET=true

SENTRY_DSN=
