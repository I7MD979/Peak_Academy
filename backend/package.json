{
  "name": "backend",
  "version": "1.0.0",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "kill-port": "node scripts/kill-port.mjs 4000",
    "predev": "node scripts/kill-port.mjs 4000",
    "dev": "node --watch src/index.js",
    "dev:keep": "node --watch src/index.js",
    "restart": "node scripts/kill-port.mjs 4000 && node src/index.js",
    "verify": "node scripts/verify-api.mjs",
    "start": "node src/index.js",
    "worker": "node src/index.js",
    "test": "node --test tests/integration.test.js tests/schema-v2.test.js",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "test:security": "vitest run tests/security/",
    "lint": "eslint src/ --ext .js",
    "setup:env": "node scripts/setup-env.mjs",
    "setup:admin": "node scripts/setup-super-admin.mjs",
    "migrate:payments": "node scripts/apply-payments-migration.mjs",
    "migrate:unify-room": "node scripts/apply-unify-room-migration.mjs",
    "migrate:verification": "node scripts/apply-verification-migration.mjs",
    "migrate:verification-security": "node scripts/apply-verification-security-migration.mjs",
    "cleanup:livekit": "node scripts/cleanup-livekit.js",
    "audit": "npm audit --audit-level=high",
    "audit:fix": "npm audit fix",
    "security:check": "npm audit --audit-level=moderate && echo Security check passed"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@sentry/node": "^9.30.0",
    "@supabase/supabase-js": "^2.106.2",
    "@upstash/redis": "^1.35.0",
    "bullmq": "^5.56.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dompurify": "^3.4.8",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.5.0",
    "express-slow-down": "^3.1.0",
    "googleapis": "^173.0.0",
    "helmet": "^8.2.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.6.1",
    "jsdom": "^29.1.1",
    "jsonwebtoken": "^9.0.3",
    "livekit-server-sdk": "^2.15.4",
    "resend": "^3.5.0",
    "stripe": "^17.7.0",
    "validator": "^13.15.35",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^9.0.0",
    "nodemon": "^3.1.14",
    "pg": "^8.21.0",
    "supertest": "^7.2.2",
    "vitest": "^4.1.8"
  }
}
