# Local dev — optional direct backend URL. If unset, localhost uses http://localhost:4000/api via api-base.js.
# Do not set NEXT_PUBLIC_API_URL to localhost on Vercel — SSR cannot reach your machine.
# NEXT_PUBLIC_API_URL=http://localhost:4000/api

# Server-only: SSR on Vercel (set in Vercel project env, not NEXT_PUBLIC_*)
# API_UPSTREAM_URL=https://peakacademy-production.up.railway.app

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
